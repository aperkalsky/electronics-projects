IDD_ABOUTBOX DIALOG DISCARDABLE  0, 0, 217, 55
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About Programmer"
FONT 8, "MS Sans Serif"
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,11,17,20,20
    LTEXT           "Programmer Version 1.0",IDC_STATIC,40,10,119,8,
                    SS_NOPREFIX
    LTEXT           "Copyright (C) 2000",IDC_STATIC,40,25,119,8
    DEFPUSHBUTTON   "OK",IDOK,178,7,32,14,WS_GROUP
END

IDD_PROGRAMMER_DIALOG DIALOGEX 0, 0, 400, 165
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
CAPTION "27C512 Programmer"
FONT 8, "MS Sans Serif", 0, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "E&xit",IDOK,175,140,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,268,140,50,14,NOT WS_VISIBLE
    CONTROL         "Progress1",IDC_PROGRESS,"msctls_progress32",WS_BORDER,
                    84,76,230,8
    GROUPBOX        "EEPROM ",IDC_STATIC_EEPROM,12,6,62,148
    GROUPBOX        "Buffer",IDC_STATIC_BUFFER,328,8,62,148
    CTEXT           "Status Line",IDC_STATIC_STATUS_LINE,88,104,222,12,
                    WS_BORDER
    GROUPBOX        "Input File",IDC_STATIC_INPUT_FILE,98,12,94,44
    GROUPBOX        "Output File",IDC_STATIC_OUTPUT_FILE,218,12,90,44
    LTEXT           "<none>",IDC_STATIC_IF_TXT,112,30,62,12,WS_BORDER
    LTEXT           "<none>",IDC_STATIC_OF_TXT,228,30,62,12,WS_BORDER
    PUSHBUTTON      "Blank &Check",IDC_BUTTON_CHECK_BLANK,16,20,50,14
    PUSHBUTTON      "&Read",IDC_BUTTON_READ,16,40,50,14
    PUSHBUTTON      "&Burn",IDC_BUTTON_BURN,16,58,50,14
    PUSHBUTTON      "&Verify",IDC_BUTTON_VERIFY,16,78,50,14
    PUSHBUTTON      "&Load",IDC_BUTTON_LOAD_BUFFER,334,22,50,14
    PUSHBUTTON      "&Save",IDC_BUTTON_SAVE_BUFFER,334,40,50,14
    PUSHBUTTON      "Cle&ar",IDC_BUTTON_CLEAR_BUFFER,334,58,50,14
    PUSHBUTTON      "&Fill",IDC_BUTTON_FILL_BUFFER,334,76,50,14
    PUSHBUTTON      "&Data Size",IDC_BUTTON_DATA_SIZE,334,94,50,14
    PUSHBUTTON      "C&hecksum",IDC_BUTTON_CHECKSUM,16,98,50,14
END

CG_IDD_PROGRESS DIALOG DISCARDABLE  0, 0, 186, 79
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
FONT 8, "MS Sans Serif"
BEGIN
