                    WS_BORDER,15,34,154,13
    LTEXT           " 0 %",CG_IDC_PROGDLG_PERCENT,85,23,18,8
    LTEXT           "",CG_IDC_PROGDLG_STATUS,13,7,158,8
END

IDD_FILL_DIALOG DIALOG DISCARDABLE  0, 0, 144, 95
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Fill Buffer"
FONT 8, "MS Sans Serif"
BEGIN
    CONTROL         "Random fill",IDC_RADIO_RANDOM,"Button",
                    BS_AUTORADIOBUTTON | WS_GROUP,13,15,51,10
